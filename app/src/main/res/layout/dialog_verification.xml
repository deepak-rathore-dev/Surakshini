<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg_dark"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="E M E R G E N C Y   T R I G G E R"
        android:textColor="#EF5350"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_dialog_alert"
        app:tint="#EF5350"
        android:background="@drawable/countdown_circle_dark"
        android:padding="10dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Potential Danger\nDetected"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Emergency services and your trusted contacts will be notified in..."
        android:textAlignment="center"
        android:textColor="#B3B3B3"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/countdown_circle_dark"
        android:layout_marginBottom="40dp">

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="10"
            android:textColor="#EF5350"
            android:textSize="64sp"
            android:textStyle="bold"/>
    </FrameLayout>

    <Button
        android:id="@+id/btnSendSosNow"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#EF5350"
        android:text="SOS  Send Emergency Alert Now"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

    <Button
        android:id="@+id/btnCancelSos"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#2C2C2C"
        android:text="I'm Safe"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your live location and Aadhaar profile will be shared with the nearest police station."
        android:textAlignment="center"
        android:textColor="#757575"
        android:textSize="11sp"/>

</LinearLayout>